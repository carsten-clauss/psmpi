# Enable the use of UCC (if available) and turn on the reporting of warnings
# (Fallbacks caused by a lack of UCC support are now reported.)
SCRIPTDIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
source ${SCRIPTDIR}/../ucc.testconf
export PSP_UCC_VERBOSE=2
export MPIR_CVAR_CH4_UCC_VERBOSITY_LEVEL=2
