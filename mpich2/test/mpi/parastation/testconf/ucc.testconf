# Enable the use of UCC (if available)
export PSP_UCC=1
export MPIR_CVAR_CH4_UCC_ENABLE=1
export UCC_LOG_LEVEL=FATAL
# Since psmgmt does not automatically export all variables, we have to do so explicitly in such cases:
mpiexec --exports= -np 1 true 2> /dev/null && export MPITEST_MPIEXECARG="${MPITEST_MPIEXECARG} --exports=MPIR_CVAR_CH4_UCC_ENABLE,UCC_LOG_LEVEL"
